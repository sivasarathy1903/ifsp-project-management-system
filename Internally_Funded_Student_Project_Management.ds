		form projects
		{
			displayname = "Projects"
			success message = "Project Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			project_id
			(
    			type = autonumber
				displayname = "Project ID"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			title
			(
    			type = text
				displayname = "Title"
	 			row = 1
	 			column = 1   
				width = medium
			)
			abstract
			(
    			type = textarea
				displayname = "Abstract"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			problem_statement
			(
    			type = textarea
				displayname = "Problem Statement"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			guide_name
			(
    			type = text
				displayname = "Guide Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			team_members
			(
    			type = text
				displayname = "Team Members"
	 			row = 1
	 			column = 1   
				width = medium
			)
			estimated_budget
			(
				displayname = "Estimated Budget"
				type = USD
	 			row = 1
	 			column = 1   
