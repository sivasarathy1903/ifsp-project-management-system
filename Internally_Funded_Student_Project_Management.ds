 application "Internally Funded Student Project Management"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form budget_breakdown
		{
			displayname = "Budget Breakdown"
			success message = "Budget Breakdown Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			project
			(
				type = list	
				displayname = "Project"
				values  = projects.ID
    			displayformat = [project_id]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
			component_name
			(
    			type = text
				displayname = "Component Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			quantity
			(
				type = number
				displayname = "Quantity"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			cost_per_unit
			(
				displayname = "Cost Per Unit"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
			total_cost
			(
				displayname = "Total Cost"
				type = USD
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Budget Entry Created","Cost Validation Pending","Budget Draft Saved","Cost Validation Failed","Cost Validation Passed","Budget Approval Requested","Budget Approved","Budget Rejected","Budget Tracking Active","Budget Exceeded Alert","Budget Fully Utilized","Budget Closed"}
			}
		}
		form milestones
		{
			displayname = "Milestones"
			success message = "Milestone Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			project
			(
				type = list	
				displayname = "Project"
				values  = projects.ID
    			displayformat = [project_id]
				allow new entries
				[
					displayname = "Add New"
				]
