			)
			milestone_name
			(
    			type = text
				displayname = "Milestone Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			deadline
			(
    			type = date
				displayname = "Deadline"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			completion_status
			(
				type = picklist
				displayname = "Completion Status"
				values = {"Not Started","Completed","In Progress"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			progress_percentage
			(
    			type = percentage
				displayname = "Progress Percentage"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
