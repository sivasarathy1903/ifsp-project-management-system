			)
			submission_date
			(
    			type = date
				displayname = "Submission Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			predicted_success_probability
			(
    			type = percentage
				displayname = "Predicted Success Probability"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
