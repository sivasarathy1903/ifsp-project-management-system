	reports
	{
		list budget_breakdown_Report
		{
			displayName = "All Budget Breakdowns"
			show all rows from budget_breakdown    
			(
				project as "Project"
				component_name as "Component Name"
				quantity as "Quantity"
				cost_per_unit as "Cost Per Unit"
				(
					display = total,average,min,max	
				)
				total_cost as "Total Cost"
				(
					display = total,average,min,max	
				)
			)
		}
		list project_sentiment_Report
		{
			displayName = "All Project Sentiments"
			show all rows from project_sentiment    
			(
				project as "Project"
				abstract_sentiment as "Abstract Sentiment"
				sentiment_confidence as "Sentiment Confidence"
				(
					display = total,average,min,max	
				)
				analysis_date as "Analysis Date"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (abstract_sentiment == "Negative")
				fields = [abstract_sentiment]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (abstract_sentiment == "Positive")
				fields = [abstract_sentiment]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (abstract_sentiment == "Very Positive")
				fields = [abstract_sentiment]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban project_sentiment_by_abstract_sentiment
		{
			displayName = "Abstract Sentiments"
			show all rows from project_sentiment    
			(
				project as "Project"
				abstract_sentiment as "Abstract Sentiment"
				sentiment_confidence as "Sentiment Confidence"
				(
					display = total,average,min,max	
				)
				analysis_date as "Analysis Date"
			)
			options
			(
	 			display field = abstract_sentiment
	 		)
		}
		list milestones_Report
		{
			displayName = "All Milestones"
			show all rows from milestones    
			(
				project as "Project"
				milestone_name as "Milestone Name"
				deadline as "Deadline"
				completion_status as "Completion Status"
				progress_percentage as "Progress Percentage"
				(
					display = total,average,min,max	
				)
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (completion_status == "Completed")
				fields = [completion_status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (completion_status == "In Progress")
				fields = [completion_status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (completion_status == "Not Started")
				fields = [completion_status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban milestones_by_completion_status
		{
			displayName = "Completion Statuses"
			show all rows from milestones    
			(
				project as "Project"
				milestone_name as "Milestone Name"
				deadline as "Deadline"
				completion_status as "Completion Status"
				progress_percentage as "Progress Percentage"
				(
					display = total,average,min,max	
				)
			)
			options
			(
	 			display field = completion_status
	 		)
		}
		list projects_Report
		{
			displayName = "All Projects"
			show all rows from projects    
			(
				project_id as "Project ID"
				title as "Title"
				abstract as "Abstract"
				problem_statement as "Problem Statement"
				guide_name as "Guide Name"
				team_members as "Team Members"
				estimated_budget as "Estimated Budget"
				(
					display = total,average,min,max	
				)
				project_duration as "Project Duration"
				status as "Status"
				submission_date as "Submission Date"
				predicted_success_probability as "Predicted Success Probability"
				(
					display = total,average,min,max	
				)
				sentiment_score as "Sentiment Score"
				reviewer as "Reviewer"
				admin as "Admin"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (status == "Rejected")
				fields = [status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (status == "Submitted")
				fields = [status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (status == "Under Review")
				fields = [status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban projects_by_status
		{
			displayName = "Statuses"
			show all rows from projects    
			(
				project_id as "Project ID"
				title as "Title"
				abstract as "Abstract"
				problem_statement as "Problem Statement"
				guide_name as "Guide Name"
				team_members as "Team Members"
				estimated_budget as "Estimated Budget"
				(
					display = total,average,min,max	
				)
				project_duration as "Project Duration"
				status as "Status"
				submission_date as "Submission Date"
				predicted_success_probability as "Predicted Success Probability"
				(
					display = total,average,min,max	
				)
				sentiment_score as "Sentiment Score"
				reviewer as "Reviewer"
				admin as "Admin"
			)
			options
			(
	 			display field = status
	 		)
		}
		list project_risk_Report
		{
			displayName = "All Project Risks"
			show all rows from project_risk    
			(
				project as "Project"
				risk_level as "Risk Level"
				risk_score as "Risk Score"
				risk_assessment_date as "Risk Assessment Date"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (risk_level == "High")
				fields = [risk_level]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (risk_level == "Low")
				fields = [risk_level]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban project_risk_by_risk_level
		{
			displayName = "Risk Levels"
			show all rows from project_risk    
			(
				project as "Project"
				risk_level as "Risk Level"
				risk_score as "Risk Score"
				risk_assessment_date as "Risk Assessment Date"
			)
			options
			(
	 			display field = risk_level
	 		)
		}
		list users_Report
		{
			displayName = "All Users"
			show all rows from users    
			(
				name  as "Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				email as "Email"
				role as "Role"
				department as "Department"
				phone as "Phone"
				last_login as "Last Login"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (role == "Admin")
				fields = [role]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (role == "Reviewer")
				fields = [role]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (role == "Student")
				fields = [role]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban users_by_role
		{
			displayName = "Roles"
			show all rows from users    
			(
				name  as "Name"
	 			(
	      			displayformat = [first_name+""+prefix+""+last_name+""+suffix]
	 			)
				email as "Email"
				role as "Role"
				department as "Department"
				phone as "Phone"
				last_login as "Last Login"
			)
			options
			(
	 			display field = role
	 		)
		}
	}
	pages
	{
		page DashBoard
